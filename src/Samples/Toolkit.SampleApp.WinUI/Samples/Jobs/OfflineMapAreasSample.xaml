<Page
    x:Class="Esri.ArcGISRuntime.Toolkit.SampleApp.Samples.Jobs.OfflineMapAreasSample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Esri.ArcGISRuntime.Toolkit.SampleApp.Samples.Jobs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:esri="using:Esri.ArcGISRuntime.UI.Controls"
    xmlns:tk="using:Esri.ArcGISRuntime.Toolkit.UI.Controls"
    xmlns:tkcommon="using:Esri.ArcGISRuntime.Toolkit"
    xmlns:tasks="using:Esri.ArcGISRuntime.Tasks"
    mc:Ignorable="d">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="400" />
        </Grid.ColumnDefinitions>

        <esri:MapView Map="{x:Bind OfflineMapAreasView.SelectedMap, Mode=OneWay}" />

        <Border HorizontalAlignment="Center" Margin="20" Padding="20" BorderThickness="2" VerticalAlignment="Top" CornerRadius="8"
                Background="{ThemeResource ControlOnImageFillColorDefaultBrush}" BorderBrush="{StaticResource CardStrokeColorDefaultBrush}">
            <StackPanel Spacing="16" Orientation="Horizontal">
            <ComboBox Header="Select Online Map" x:Name="MapSelector" ItemsSource="{x:Bind Maps}" SelectedIndex="0" Width="250"
                      SelectionChanged="OnlineMapSelection_Changed" />

            <ComboBox Header="Select Offline Map Info" x:Name="OfflineMapSelector" ItemsSource="{x:Bind OfflineMapInfos, Mode=OneWay}" Width="250"
                      SelectionChanged="OfflineMapSelection_Changed">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="tkcommon:OfflineMapInfo">
                        <StackPanel Orientation="Horizontal" Width="250">
                            <Image Source="{x:Bind local:OfflineMapAreasSample.BytesToImage(ThumbnailData)}" MaxWidth="64" Height="64" />
                            <TextBlock Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="4" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Map Areas" Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" />
            <tk:OfflineMapAreasView x:Name="OfflineMapAreasView" Grid.Row="1" />
            <Button Command="{x:Bind OfflineMapAreasView.GoOnlineCommand}" Content="Go Online" Grid.Row="2" HorizontalAlignment="Stretch" Background="{ThemeResource AccentFillColorDefaultBrush}" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
        </Grid>

    </Grid>
</Page>

