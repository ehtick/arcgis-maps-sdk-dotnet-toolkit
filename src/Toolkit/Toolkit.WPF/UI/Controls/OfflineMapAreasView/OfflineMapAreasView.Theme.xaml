<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:internal="clr-namespace:Esri.ArcGISRuntime.Toolkit.Internal"
    xmlns:controls="clr-namespace:Esri.ArcGISRuntime.Toolkit.UI.Controls">
    <FontFamily x:Key="ToolkitIconsFontFamily">pack://application:,,,/Esri.ArcGISRuntime.Toolkit.WPF;component/Assets/toolkit-icons.ttf#calcite-ui-icons-24</FontFamily>
    <internal:VisibilityConverter x:Key="OfflineMapAreasViewVisibilityConverter"/>
    
    <Style x:Key="OfflineMapAreasViewIconButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="OfflineMapAreasViewStatePanelStyle" TargetType="{x:Type StackPanel}">
        <Setter Property="Visibility" Value="Collapsed" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="MaxWidth" Value="320" />
    </Style>

    <Style TargetType="{x:Type controls:OfflineMapAreasView}">
        <!--  Default item template can be overriden by the user.  -->
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Grid
                        Height="68"
                        Margin="0,4"
                        AutomationProperties.Name="{Binding Title}"
                        AutomationProperties.HelpText="{Binding Description}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="68" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.ColumnSpan="3" Grid.RowSpan="3" Visibility="{Binding IsOpen, Converter={StaticResource OfflineMapAreasViewVisibilityConverter}, Mode=OneWay}"
                                Background="#0067C0" CornerRadius="8" Opacity=".2" />
                        <Border
                            Grid.RowSpan="3"
                            Margin="0,0,4,0"
                            BorderBrush="LightGray"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Image
                                Width="64"
                                Height="64"
                                Source="{Binding ThumbnailData}"
                                Stretch="UniformToFill" />
                        </Border>

                        <TextBlock
                            Grid.Column="1"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{Binding Title}"
                            TextTrimming="CharacterEllipsis" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            MaxHeight="34"
                            Margin="0,2,0,0"
                            Foreground="#FF666666"
                            Text="{Binding Description}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Grid.Row="2" Grid.Column="1"
                            Foreground="#FF666666"
                            Text="{internal:LocalizedString Key=OfflineMapAreasDownloaded}" Visibility="{Binding IsDownloaded, Converter={StaticResource OfflineMapAreasViewVisibilityConverter}, Mode=OneWay}">
                        </TextBlock>

                        <Grid Grid.RowSpan="3" Grid.Column="2">
                            <Button
                                  AutomationProperties.Name="{internal:LocalizedString Key=OfflineMapAreasStop}"
                                  AutomationProperties.HelpText="{Binding Title}"
                                  Command="{Binding StopDownloadCommand}" Style="{StaticResource OfflineMapAreasViewIconButtonStyle}" 
                                  ToolTipService.ToolTip="{internal:LocalizedString Key=OfflineMapAreasStop}" Visibility="{Binding IsDownloading, Converter={StaticResource OfflineMapAreasViewVisibilityConverter}, Mode=OneWay}">
                                <TextBlock FontFamily="{StaticResource ToolkitIconsFontFamily}" FontSize="14" Text="&#xE7B3;" />
                            </Button>

                            <Button
                                 AutomationProperties.Name="{internal:LocalizedString Key=OfflineMapAreasDownload}"
                                 AutomationProperties.HelpText="{Binding Title}"
                                 Command="{Binding DownloadCommand}"
                                 ToolTipService.ToolTip="{internal:LocalizedString Key=OfflineMapAreasDownload}"
                                 Style="{StaticResource OfflineMapAreasViewIconButtonStyle}" 
                                 Visibility="{Binding AllowsDownload, Converter={StaticResource OfflineMapAreasViewVisibilityConverter}, Mode=OneWay}">
                                <TextBlock FontFamily="{StaticResource ToolkitIconsFontFamily}" FontSize="16" Text="&#xE81C;" />
                            </Button>

                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsDownloaded, Converter={StaticResource OfflineMapAreasViewVisibilityConverter}, Mode=OneWay}">
                                <Button
                                    AutomationProperties.Name="{internal:LocalizedString Key=OfflineMapAreasRemove}"
                                    AutomationProperties.HelpText="{Binding Title}"
                                    Command="{Binding RemoveDownloadCommand}"
                                    Style="{StaticResource OfflineMapAreasViewIconButtonStyle}"
                                    Visibility="{Binding IsOpen, Converter={StaticResource OfflineMapAreasViewVisibilityConverter}, ConverterParameter=Reverse, Mode=OneWay}"
                                    ToolTipService.ToolTip="{internal:LocalizedString Key=OfflineMapAreasRemove}">
                                    <TextBlock FontFamily="{StaticResource ToolkitIconsFontFamily}" FontSize="14" Text="&#xEB04;" />
                                </Button>
                                <Button
                                    Margin="8,0,0,0" VerticalAlignment="Center"
                                    AutomationProperties.HelpText="{Binding Title}"
                                    Command="{Binding OpenCommand}"
                                    CommandParameter="{Binding Map}"
                                    Visibility="{Binding IsOpen, Converter={StaticResource OfflineMapAreasViewVisibilityConverter}, ConverterParameter=Reverse, Mode=OneWay}"
                                    Content="{internal:LocalizedString Key=OfflineMapAreasOpen}" />
                            </StackPanel>
                            <Button Margin="8,0,0,0" VerticalAlignment="Center"
                                    AutomationProperties.Name="{internal:LocalizedString Key=OfflineMapAreasRemoveOnError}"
                                    AutomationProperties.HelpText="{Binding Error.Message, Mode=OneWay}"
                                    ToolTipService.ToolTip="{Binding Error.Message, Mode=OneWay}"
                                    Command="{Binding RemoveDownloadCommand, Mode=OneWay}" Visibility="{Binding Error, Converter={StaticResource OfflineMapAreasViewVisibilityConverter}, Mode=OneWay}">
                                <TextBlock FontFamily="{StaticResource ToolkitIconsFontFamily}" FontSize="16" Text="&#xE844;" />
                            </Button>
                        </Grid>
                        <ProgressBar
                             Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2"
                             Minimum="0" Maximum="1" VerticalAlignment="Bottom"
                             IsIndeterminate="False" IsHitTestVisible="False"
                             Value="{Binding DownloadProgress, Mode=OneWay}" Visibility="{Binding IsDownloading, Converter={StaticResource OfflineMapAreasViewVisibilityConverter}, Mode=OneWay}"/>

                    </Grid>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:OfflineMapAreasView}">
                    <Border
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Padding="{TemplateBinding Padding}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}" Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.IsAddOnDemandMode,Converter={StaticResource OfflineMapAreasViewVisibilityConverter}, ConverterParameter=Reverse}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ItemsControl 
                                    AutomationProperties.Name="{TemplateBinding AutomationProperties.Name}"
                                    AutomationProperties.HelpText="{TemplateBinding AutomationProperties.HelpText}"
                                    x:Name="MapAreasView"
                                    Grid.Row="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    ItemsSource="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.MapAreas}"
                                    ItemTemplate="{TemplateBinding ItemTemplate}"
                                    IsTabStop="False"/>

                                <StackPanel Grid.Row="0">
                                    <StackPanel.Style>
                                        <Style BasedOn="{StaticResource OfflineMapAreasViewStatePanelStyle}" TargetType="{x:Type StackPanel}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.MapIsOfflineDisabled}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontFamily="{StaticResource ToolkitIconsFontFamily}"
                                        FontSize="48"
                                        Foreground="#FF8A8A8A"
                                        Text="&#xE846;" />
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="20"
                                        FontWeight="SemiBold"
                                        Text="{internal:LocalizedString Key=OfflineMapAreasOfflineDisabledTitle}"
                                        TextAlignment="Center" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Center"
                                        Foreground="#FF666666"
                                        Text="{internal:LocalizedString Key=OfflineMapAreasOfflineDisabledMessage}"
                                        TextAlignment="Center"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Row="0">
                                    <StackPanel.Style>
                                        <Style BasedOn="{StaticResource OfflineMapAreasViewStatePanelStyle}" TargetType="{x:Type StackPanel}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.IsInternetNotAvailable}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontFamily="{StaticResource ToolkitIconsFontFamily}"
                                        FontSize="48"
                                        Foreground="#FF8A8A8A"
                                        Text="&#xE846;" />
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="20"
                                        FontWeight="SemiBold"
                                        Text="{internal:LocalizedString Key=OfflineMapAreasNoInternetConnectionTitle}"
                                        TextAlignment="Center" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Center"
                                        Foreground="#FF666666"
                                        Text="{internal:LocalizedString Key=OfflineMapAreasNoInternetConnectionMessage}"
                                        TextAlignment="Center"
                                        TextWrapping="Wrap" />
                                    <Button
                                        x:Name="NoInternetRefreshButton"
                                        Margin="0,12,0,0"
                                        HorizontalAlignment="Center"
                                        AutomationProperties.HelpText="{internal:LocalizedString Key=OfflineMapAreasRefresh}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                Margin="0,0,4,0"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource ToolkitIconsFontFamily}"
                                                FontSize="14"
                                                Text="&#xE72C;" />
                                            <TextBlock Text="{internal:LocalizedString Key=OfflineMapAreasRefresh}" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <StackPanel Grid.Row="0">
                                    <StackPanel.Style>
                                        <Style BasedOn="{StaticResource OfflineMapAreasViewStatePanelStyle}" TargetType="{x:Type StackPanel}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.HasNoAreas}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontFamily="{StaticResource ToolkitIconsFontFamily}"
                                        FontSize="48"
                                        Foreground="#FF8A8A8A"
                                        Text="&#xE81C;" />
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="20"
                                        FontWeight="SemiBold"
                                        Text="{internal:LocalizedString Key=OfflineMapAreasNoMapAreasTitle}"
                                        TextAlignment="Center" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Center"
                                        Foreground="#FF666666"
                                        Text="{internal:LocalizedString Key=OfflineMapAreasNoMapAreasPreplannedMessage}">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Setter Property="TextAlignment" Value="Center" />
                                                <Setter Property="TextWrapping" Value="Wrap" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.IsPreplannedMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Center"
                                        Foreground="#FF666666"
                                        Text="{internal:LocalizedString Key=OfflineMapAreasNoMapAreasOnDemandMessage}">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Setter Property="TextAlignment" Value="Center" />
                                                <Setter Property="TextWrapping" Value="Wrap" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.IsOnDemandMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button
                                        x:Name="RefreshMapAreasButton"
                                        Margin="0,12,0,0"
                                        HorizontalAlignment="Center"
                                        AutomationProperties.HelpText="{internal:LocalizedString Key=OfflineMapAreasRefresh}">
                                        <Button.Style>
                                            <Style TargetType="{x:Type Button}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.IsPreplannedMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                Margin="0,0,4,0"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource ToolkitIconsFontFamily}"
                                                FontSize="14"
                                                Text="&#xE72C;" />
                                            <TextBlock Text="{internal:LocalizedString Key=OfflineMapAreasRefresh}" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <ProgressBar
                                    Grid.Row="0"
                                    Width="120"
                                    Height="4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsIndeterminate="True">
                                    <ProgressBar.Style>
                                        <Style TargetType="{x:Type ProgressBar}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.IsLoadingModels}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>

                                <Button
                                    x:Name="AddMapAreaButton"
                                    Grid.Row="1"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Center"
                                    AutomationProperties.Name="{internal:LocalizedString Key=OfflineMapAreasAddMapArea}">
                                    <Button.Style>
                                        <Style TargetType="{x:Type Button}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.CanAddMapArea}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource ToolkitIconsFontFamily}"
                                            FontSize="18"
                                            Text="&#xE9F6;" />
                                        <TextBlock VerticalAlignment="Center" Text="{internal:LocalizedString Key=OfflineMapAreasAddMapArea}" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </ScrollViewer>
                        <!-- Add Map Area View -->
                        <Grid Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.IsAddOnDemandMode,Converter={StaticResource OfflineMapAreasViewVisibilityConverter}}" Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition MaxHeight="400" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{internal:LocalizedString Key=OfflineMapAreasSelectArea}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                            <Grid Grid.Row="1" Margin="0,8">
                                <esri:MapView xmlns:esri="http://schemas.esri.com/arcgis/runtime/2013" ViewInsets="20" MinHeight="100"
                                    x:Name="AddAreaMapView" Grid.Row="1" IsAttributionTextVisible="False" BorderBrush="Black" BorderThickness="1" />
                                <Border BorderBrush="Black" BorderThickness="20" IsHitTestVisible="False" Opacity=".5" />
                            </Grid>
                            <TextBlock x:Name="OfflineMapAreasScaleLabel" Grid.Row="2" Text="{internal:LocalizedString Key=OfflineMapAreasScaleLabel}" />
                            <ComboBox AutomationProperties.LabeledBy="{Binding ElementName=OfflineMapAreasScaleLabel}" Grid.Row="3" x:Name="AddOnDemandAreaScaleSelector" DisplayMemberPath="DisplayName" HorizontalAlignment="Stretch" />
                            <TextBlock x:Name="OfflineMapAreasAreaNamePlaceholder" Grid.Row="4" Text="{internal:LocalizedString Key=OfflineMapAreasAreaNamePlaceholder}" />
                            <TextBox Grid.Row="5" x:Name="AddOnDemandAreaNameTextBox" AutomationProperties.LabeledBy="{Binding ElementName=OfflineMapAreasAreaNamePlaceholder}"/>
                            <Button Content="{internal:LocalizedString Key=OfflineMapAreasAdd}" Grid.Row="6" HorizontalAlignment="Stretch" x:Name="AcceptAddOnDemandAreaButton" Margin="0,8,0,0" />
                            <Button Content="{internal:LocalizedString Key=OfflineMapAreasCancel}" HorizontalAlignment="Right" x:Name="CancelAddOnDemandAreaButton" />

                        </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="IsTabStop" Value="False" />
    </Style>
</ResourceDictionary>
