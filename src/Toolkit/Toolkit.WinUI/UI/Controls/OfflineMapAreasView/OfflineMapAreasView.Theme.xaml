<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="Esri.ArcGISRuntime.Toolkit.OfflineMapAreasViewResources"
    xmlns:esri="using:Esri.ArcGISRuntime.UI.Controls"
    xmlns:controls="using:Esri.ArcGISRuntime.Toolkit.UI.Controls"
    xmlns:internal="using:Esri.ArcGISRuntime.Toolkit.Internal"
    xmlns:local="using:Esri.ArcGISRuntime.Toolkit">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../../../Themes/SharedResources.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="OfflineMapAreasViewButtonStyle" TargetType="Button">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style TargetType="controls:OfflineMapAreasView">
        <!--  Default item template can be overriden by the user.  -->
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate x:DataType="controls:IOfflineMapAreaItem">
                    <Grid Height="64" Margin="0,4"
                          AutomationProperties.Name="{x:Bind Title, Mode=OneWay}" 
                          AutomationProperties.FullDescription="{x:Bind Description, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="68" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.ColumnSpan="3" Grid.RowSpan="3" Visibility="{x:Bind IsOpen, Mode=OneWay}"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                Margin="0,0" CornerRadius="8" Opacity=".2" />
                        <Border CornerRadius="8" Grid.RowSpan="3" BorderThickness="1" BorderBrush="LightGray" Margin="0,0,4,0">
                            <Image Source="{x:Bind local:OfflineMapAreasViewResources.BytesToImage(ThumbnailData), Mode=OneWay}" Width="64" Height="64" Stretch="UniformToFill"/>
                        </Border>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind Title, Mode=OneWay}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind Description, Mode=OneWay}" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxLines="3" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Text="{internal:LocalizedString Key=OfflineMapAreasDownloaded}" Grid.Row="2" Grid.Column="1" Visibility="{x:Bind IsDownloaded, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" />
                        <Grid Grid.Column="2" Grid.RowSpan="3">
                            <Button Style="{StaticResource OfflineMapAreasViewButtonStyle}" AutomationProperties.Name="{internal:LocalizedString Key=OfflineMapAreasStop}" ToolTipService.ToolTip="{internal:LocalizedString Key=OfflineMapAreasStop}" Command="{x:Bind StopDownloadCommand, Mode=OneWay}" Visibility="{x:Bind IsDownloading, Mode=OneWay}">
                                <SymbolIcon Symbol="Stop" />
                            </Button>
                            <Button Style="{StaticResource OfflineMapAreasViewButtonStyle}" AutomationProperties.Name="{internal:LocalizedString Key=OfflineMapAreasDownload}" ToolTipService.ToolTip="{internal:LocalizedString Key=OfflineMapAreasDownload}" Command="{x:Bind DownloadCommand, Mode=OneWay}" Visibility="{x:Bind AllowsDownload, Mode=OneWay}">
                                <SymbolIcon Symbol="Download" />
                            </Button>
                            <ProgressRing Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" Minimum="0" Maximum="1" IsIndeterminate="False" Value="{x:Bind DownloadProgress, Mode=OneWay}" Visibility="{x:Bind IsDownloading, Mode=OneWay}" />
                            <StackPanel Orientation="Horizontal" Visibility="{x:Bind IsDownloaded, Mode=OneWay}" >
                                <Button Style="{StaticResource OfflineMapAreasViewButtonStyle}" ToolTipService.ToolTip="{internal:LocalizedString Key=OfflineMapAreasRemove}" AutomationProperties.Name="{internal:LocalizedString Key=OfflineMapAreasRemove}" Command="{x:Bind RemoveDownloadCommand, Mode=OneWay}"
                                        Visibility="{x:Bind local:OfflineMapAreasViewResources.FalseToVisible(IsOpen), Mode=OneWay}" >
                                    <SymbolIcon Symbol="Delete" />
                                </Button>
                                <Button Content="{internal:LocalizedString Key=OfflineMapAreasOpen}" AutomationProperties.HelpText="{internal:LocalizedString Key=OfflineMapAreasOpen}" Margin="8,0,0,0" Command="{x:Bind OpenCommand, Mode=OneWay}" CommandParameter="{x:Bind Map, Mode=OneWay}"
                                        Visibility="{x:Bind local:OfflineMapAreasViewResources.FalseToVisible(IsOpen), Mode=OneWay}" />
                            </StackPanel>
                            <Button Style="{StaticResource OfflineMapAreasViewButtonStyle}"
                                    AutomationProperties.Name="{internal:LocalizedString Key=OfflineMapAreasRemoveOnError}"
                                    AutomationProperties.FullDescription="{x:Bind Error.Message, Mode=OneWay}"
                                    ToolTipService.ToolTip="{x:Bind Error.Message, Mode=OneWay}"
                                    Command="{x:Bind RemoveDownloadCommand, Mode=OneWay}" Visibility="{x:Bind local:OfflineMapAreasViewResources.VisibleIfNotNull(Error), Mode=OneWay}">
                                <FontIcon Glyph="&#xE783;" />
                            </Button>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:OfflineMapAreasView">
                    <Border
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                        <Border.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{ThemeResource ControlFillColorDefault}" />
                        </Border.Resources>
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}" Visibility="{x:Bind local:OfflineMapAreasViewResources.FalseToVisible(TemplateSettings.IsAddOnDemandMode), Mode=OneWay}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ItemsControl x:Name="MapAreasView" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsTabStop="False"

                                        ItemsSource="{x:Bind TemplateSettings.MapAreas, Mode=OneWay}" ItemTemplate="{TemplateBinding ItemTemplate}"/>

                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{x:Bind TemplateSettings.MapIsOfflineDisabled, Mode=OneWay}">
                                        <TextBlock
                                            Grid.Column="0" Foreground="{StaticResource TextFillColorTertiaryBrush}"
                                            HorizontalAlignment="Center"
                                            FontFamily="{StaticResource toolkit-icons}"
                                           Text="&#xE846;" FontSize="48" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{internal:LocalizedString Key=OfflineMapAreasOfflineDisabledTitle}" TextTrimming="CharacterEllipsis" Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{internal:LocalizedString Key=OfflineMapAreasOfflineDisabledMessage}" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{x:Bind TemplateSettings.IsInternetNotAvailable, Mode=OneWay}">
                                        <TextBlock
                                            Grid.Column="0" Foreground="{StaticResource TextFillColorTertiaryBrush}"
                                            HorizontalAlignment="Center"
                                            FontFamily="{StaticResource toolkit-icons}"
                                           Text="&#xE846;" FontSize="48" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{internal:LocalizedString Key=OfflineMapAreasNoInternetConnectionTitle}" TextTrimming="CharacterEllipsis" Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{internal:LocalizedString Key=OfflineMapAreasNoInternetConnectionMessage}" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                                        <Button HorizontalAlignment="Center" AutomationProperties.HelpText="{internal:LocalizedString Key=OfflineMapAreasRefresh}" x:Name="NoInternetRefreshButton">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xEB66;" FontFamily="{StaticResource toolkit-icons}" VerticalAlignment="Center" FontSize="14" Margin="0,0,4,0" />
                                                <TextBlock Text="{internal:LocalizedString Key=OfflineMapAreasRefresh}"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{x:Bind TemplateSettings.HasNoAreas, Mode=OneWay}">
                                        <TextBlock
                                        Grid.Column="0" Foreground="{StaticResource TextFillColorTertiaryBrush}"
                                        HorizontalAlignment="Center"
                                        FontFamily="{StaticResource toolkit-icons}"
                                       Text="&#xE81C;" FontSize="48" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{internal:LocalizedString Key=OfflineMapAreasNoMapAreasTitle}" TextTrimming="CharacterEllipsis" Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{internal:LocalizedString Key=OfflineMapAreasNoMapAreasPreplannedMessage}" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Foreground="{StaticResource TextFillColorSecondaryBrush}"
                                               Visibility="{x:Bind TemplateSettings.IsPreplannedMode, Mode=OneWay}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{internal:LocalizedString Key=OfflineMapAreasNoMapAreasOnDemandMessage}" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Foreground="{StaticResource TextFillColorSecondaryBrush}"
                                               Visibility="{x:Bind TemplateSettings.IsOnDemandMode, Mode=OneWay}" />
                                        <Button HorizontalAlignment="Center" Visibility="{x:Bind TemplateSettings.IsPreplannedMode, Mode=OneWay}" AutomationProperties.HelpText="{internal:LocalizedString Key=OfflineMapAreasRefresh}" x:Name="RefreshMapAreasButton">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xEB66;" FontFamily="{StaticResource toolkit-icons}" VerticalAlignment="Center" FontSize="14" Margin="0,0,4,0" />
                                                <TextBlock Text="{internal:LocalizedString Key=OfflineMapAreasRefresh}"/>
                                            </StackPanel>
                                        </Button>

                                    </StackPanel>

                                    <ProgressRing Visibility="{x:Bind TemplateSettings.IsLoadingModels, Mode=OneWay}" IsHitTestVisible="False" />

                                    <Grid Grid.Row="1" Visibility="{x:Bind local:OfflineMapAreasViewResources.FalseToVisible(TemplateSettings.IsInternetNotAvailable), Mode=OneWay}" >
                                        <Button HorizontalAlignment="Center" Visibility="{x:Bind TemplateSettings.CanAddMapArea, Mode=OneWay}" AutomationProperties.HelpText="{internal:LocalizedString Key=OfflineMapAreasAddMapArea}" x:Name="AddMapAreaButton" Margin="4" Padding="24,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE9F6;" FontFamily="{StaticResource toolkit-icons}" FontSize="20" VerticalAlignment="Center" Margin="0,2,0,0" />
                                                <TextBlock Text="{internal:LocalizedString Key=OfflineMapAreasAddMapArea}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </ScrollViewer>
                            <!-- Add Map Area View -->
                            <Grid Visibility="{x:Bind TemplateSettings.IsAddOnDemandMode, Mode=OneWay}" RowSpacing="8" Margin="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition MaxHeight="400" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="{internal:LocalizedString Key=OfflineMapAreasSelectArea}" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <Grid Grid.Row="1" >
                                    <esri:MapView x:Name="AddAreaMapView" Grid.Row="1" IsAttributionTextVisible="False" BorderBrush="Black" BorderThickness="1" x:Load="False" ViewInsets="20" MinHeight="100" />
                                    <Border BorderBrush="Black" BorderThickness="20" IsHitTestVisible="False" Opacity=".5" />
                                </Grid>
                                <ComboBox Header="{internal:LocalizedString Key=OfflineMapAreasScaleLabel}" Grid.Row="2" x:Name="AddOnDemandAreaScaleSelector" HorizontalAlignment="Stretch" />
                                <TextBox Header="{internal:LocalizedString Key=OfflineMapAreasAreaNamePlaceholder}" Grid.Row="3" x:Name="AddOnDemandAreaNameTextBox" />
                                <Button Content="{internal:LocalizedString Key=OfflineMapAreasAdd}" Grid.Row="4" HorizontalAlignment="Stretch" x:Name="AcceptAddOnDemandAreaButton" />
                                <Button Content="{internal:LocalizedString Key=OfflineMapAreasCancel}" HorizontalAlignment="Right" x:Name="CancelAddOnDemandAreaButton" />

                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="IsTabStop" Value="False" />
    </Style>
</ResourceDictionary>
